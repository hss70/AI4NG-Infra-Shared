{
  "info": {
    "name": "AI4NG Authentication API",
    "description": "Test collection for AI4NG Cognito authentication flows",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "cognito_endpoint",
      "value": "https://cognito-idp.eu-west-2.amazonaws.com/",
      "type": "string"
    },
    {
      "key": "user_pool_id",
      "value": "{{$guid}}",
      "type": "string",
      "description": "Replace with your User Pool ID from CloudFormation outputs"
    },
    {
      "key": "participant_client_id",
      "value": "{{$guid}}",
      "type": "string",
      "description": "Replace with Participant Client ID from CloudFormation outputs"
    },
    {
      "key": "portal_client_id",
      "value": "{{$guid}}",
      "type": "string",
      "description": "Replace with Portal Client ID from CloudFormation outputs"
    },
    {
      "key": "test_username",
      "value": "testuser@example.com",
      "type": "string"
    },
    {
      "key": "temp_password",
      "value": "TempPass123!",
      "type": "string"
    },
    {
      "key": "new_password",
      "value": "NewPassword123!",
      "type": "string"
    },
    {
      "key": "session_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string",
      "description": "Copy from login response to test token refresh"
    }
  ],
  "item": [
    {
      "name": "Admin - Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-amz-json-1.1"
          },
          {
            "key": "X-Amz-Target",
            "value": "AWSCognitoIdentityProviderService.AdminCreateUser"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"UserPoolId\": \"{{user_pool_id}}\",\n    \"Username\": \"{{test_username}}\",\n    \"TemporaryPassword\": \"{{temp_password}}\",\n    \"MessageAction\": \"SUPPRESS\",\n    \"UserAttributes\": [\n        {\n            \"Name\": \"email\",\n            \"Value\": \"{{test_username}}\"\n        },\n        {\n            \"Name\": \"name\",\n            \"Value\": \"Test User\"\n        }\n    ]\n}"
        },
        "url": {
          "raw": "{{cognito_endpoint}}",
          "host": ["{{cognito_endpoint}}"]
        },
        "description": "Creates a new user with temporary password. Requires AWS credentials."
      }
    },
    {
      "name": "Step 1 - First Login (Get Challenge)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    if (response.Session) {",
              "        pm.collectionVariables.set('session_token', response.Session);",
              "        console.log('Session token saved for next request');",
              "    }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-amz-json-1.1"
          },
          {
            "key": "X-Amz-Target",
            "value": "AWSCognitoIdentityProviderService.InitiateAuth"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"ClientId\": \"{{participant_client_id}}\",\n    \"AuthFlow\": \"USER_PASSWORD_AUTH\",\n    \"AuthParameters\": {\n        \"USERNAME\": \"{{test_username}}\",\n        \"PASSWORD\": \"{{temp_password}}\"\n    }\n}"
        },
        "url": {
          "raw": "{{cognito_endpoint}}",
          "host": ["{{cognito_endpoint}}"]
        },
        "description": "First login attempt with temporary password. Should return NEW_PASSWORD_REQUIRED challenge."
      }
    },
    {
      "name": "Step 2 - Set New Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-amz-json-1.1"
          },
          {
            "key": "X-Amz-Target",
            "value": "AWSCognitoIdentityProviderService.RespondToAuthChallenge"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"ClientId\": \"{{participant_client_id}}\",\n    \"ChallengeName\": \"NEW_PASSWORD_REQUIRED\",\n    \"Session\": \"{{session_token}}\",\n    \"ChallengeResponses\": {\n        \"USERNAME\": \"{{test_username}}\",\n        \"NEW_PASSWORD\": \"{{new_password}}\"\n    }\n}"
        },
        "url": {
          "raw": "{{cognito_endpoint}}",
          "host": ["{{cognito_endpoint}}"]
        },
        "description": "Responds to NEW_PASSWORD_REQUIRED challenge with new permanent password. Returns JWT tokens."
      }
    },
    {
      "name": "Step 3 - Regular Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-amz-json-1.1"
          },
          {
            "key": "X-Amz-Target",
            "value": "AWSCognitoIdentityProviderService.InitiateAuth"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"ClientId\": \"{{participant_client_id}}\",\n    \"AuthFlow\": \"USER_PASSWORD_AUTH\",\n    \"AuthParameters\": {\n        \"USERNAME\": \"{{test_username}}\",\n        \"PASSWORD\": \"{{new_password}}\"\n    }\n}"
        },
        "url": {
          "raw": "{{cognito_endpoint}}",
          "host": ["{{cognito_endpoint}}"]
        },
        "description": "Regular login after password has been set. Should return JWT tokens immediately."
      }
    },
    {
      "name": "Portal Client Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-amz-json-1.1"
          },
          {
            "key": "X-Amz-Target",
            "value": "AWSCognitoIdentityProviderService.InitiateAuth"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"ClientId\": \"{{portal_client_id}}\",\n    \"AuthFlow\": \"USER_PASSWORD_AUTH\",\n    \"AuthParameters\": {\n        \"USERNAME\": \"{{test_username}}\",\n        \"PASSWORD\": \"{{new_password}}\"\n    }\n}"
        },
        "url": {
          "raw": "{{cognito_endpoint}}",
          "host": ["{{cognito_endpoint}}"]
        },
        "description": "Login using Portal client (for web application). Different token expiry times."
      }
    },
    {
      "name": "Refresh Token - Participant",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-amz-json-1.1"
          },
          {
            "key": "X-Amz-Target",
            "value": "AWSCognitoIdentityProviderService.InitiateAuth"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"ClientId\": \"{{participant_client_id}}\",\n    \"AuthFlow\": \"REFRESH_TOKEN_AUTH\",\n    \"AuthParameters\": {\n        \"REFRESH_TOKEN\": \"{{refresh_token}}\"\n    }\n}"
        },
        "url": {
          "raw": "{{cognito_endpoint}}",
          "host": ["{{cognito_endpoint}}"]
        },
        "description": "Refresh access token using refresh token. Copy refresh token from login response."
      }
    },
    {
      "name": "Refresh Token - Portal",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-amz-json-1.1"
          },
          {
            "key": "X-Amz-Target",
            "value": "AWSCognitoIdentityProviderService.InitiateAuth"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"ClientId\": \"{{portal_client_id}}\",\n    \"AuthFlow\": \"REFRESH_TOKEN_AUTH\",\n    \"AuthParameters\": {\n        \"REFRESH_TOKEN\": \"{{refresh_token}}\"\n    }\n}"
        },
        "url": {
          "raw": "{{cognito_endpoint}}",
          "host": ["{{cognito_endpoint}}"]
        },
        "description": "Refresh access token using portal client refresh token."
      }
    }
  ]
}